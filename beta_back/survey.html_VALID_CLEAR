<script>

function downloadSurveyToFile(result, fileName) {
    alert("About to download Survey to: "+fileName)
    const blob = new Blob([result], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = fileName;
    a.click();
    URL.revokeObjectURL(url);
}

document.addEventListener('DOMContentLoaded', function() {
    let currentStep = 0;
    const steps = document.querySelectorAll(".step");

    function showSection(n) {
        steps.forEach((s, index) => s.classList.toggle("active", index === n));
        document.getElementById("prevBtn").style.visibility = n === 0 ? "hidden" : "visible";
        document.getElementById("nextBtn").style.display = n === steps.length - 1 ? "none" : "inline-block";
    }

    function changeStep(n) {
        currentStep += n;
        if (currentStep >= 0 && currentStep < steps.length) {
            showSection(currentStep);
            window.scrollTo(0, 0);
        }
    }

    // Make changeStep available globally
    window.changeStep = changeStep;

function changeStep(n) {
    currentStep += n;
    showSection(currentStep);
    window.scrollTo(0,0);
}


// ==================== Core Functionality ====================

// Save single field on change/blur
document.querySelectorAll('input, textarea, select').forEach(el => {
  el.addEventListener('input', saveField);
  el.addEventListener('change', saveField);
  el.addEventListener('blur', saveField);
});

function saveField(e) {
  const id = e.target.id;
  const value = e.target.value.trim();
  if (id) localStorage.setItem(id, value);
}

// Load all saved values when page loads
function loadAllData() {
  document.querySelectorAll('input, textarea, select').forEach(el => {
    const saved = localStorage.getItem(el.id);
    if (saved !== null) el.value = saved;
  });
}


