            document.body.appendChild(notification);

            // Remove notification after 5 seconds
            setTimeout(() => {
                notification.remove();
	        // Redirect to the steps page
                window.location.href = "https://3dlifestrategies.org/beta/steps.html";
            }, 5000);            
        })
        .catch(function(error) {
            console.error('Failed to send email:', error);
            alert('Failed to send email. Error: ' + JSON.stringify(error));

            // Show error message
            const errorMessage = error.text || error.message || 'Unknown error occurred';
            const notification = document.createElement('div');
            notification.style.cssText = 'position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background-color: #ef4444; color: white; padding: 1.5rem; border-radius: 0.5rem; box-shadow: 0 10px 15px rgba(0,0,0,0.1); z-index: 9999; max-width: 400px;';
